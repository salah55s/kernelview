# KernelView Agent — Multi-stage Docker Build
# Runs as a DaemonSet with specific kernel capabilities
FROM golang:1.22-bookworm AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o kernelview-agent ./cmd/agent/

# Runtime
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /build/kernelview-agent /usr/local/bin/kernelview-agent
COPY --from=builder /build/bpf/*.o /opt/kernelview/bpf/

ENTRYPOINT ["/usr/local/bin/kernelview-agent"]
